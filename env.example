# Production Supabase Configuration
# Copy this to .env and fill in your production values

# Client-side (Expo) - Public keys
APP_ENV=production
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key-here

# Server-side clients & scripts
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# AI API Keys
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# FatSecret (server-side via Supabase Edge Function)
# Set these as Supabase Edge Function secrets in production.
FATSECRET_CLIENT_ID=your-fatsecret-client-id
FATSECRET_CLIENT_SECRET=your-fatsecret-client-secret
# Optional: leave blank to request all scopes available to your FatSecret app
FATSECRET_OAUTH2_SCOPE=

# Other environment variables
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token
REVENUECAT_APPLE_API_KEY=your-revenuecat-apple-key
REVENUECAT_GOOGLE_API_KEY=your-revenuecat-google-key
REVENUECAT_TEST_STORE_KEY=your-revenuecat-test-key
REVENUECAT_USE_TEST_STORE=false

# Facebook/Meta SDK (for ads attribution)
# Get these from https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_CLIENT_TOKEN=your-facebook-client-token

# DeeplinkNow (share-with-friends deep links)
# Domain host used by DeeplinkNow links (no protocol), e.g. yourapp.dlnk.to
# If unsure, create one deeplink in dashboard and copy just its host.
EXPO_PUBLIC_DEEPLINKNOW_DOMAIN=your-deeplinknow-domain
# Supabase Edge Function secret (server-side only, do NOT expose in app env)
DEEPLINKNOW_PRIVATE_API_KEY=your-deeplinknow-private-api-key
# Optional: same host for server-side fallback URL generation
DEEPLINKNOW_DOMAIN=your-deeplinknow-domain
